"""GitHub API utilities for fetching repository information."""

import logging
import os
from typing import TypedDict

import requests

GITHUB_API_BASE = "https://api.github.com"
GITHUB_TOKEN = os.getenv("GITHUB_TOKEN")

logger = logging.getLogger(__name__)


class RepoInfo(TypedDict):
    """Repository information structure."""
    stars: int
    forks: int
    description: str
    full_name: str
    language: str | None


def get_repo_info(owner: str, repo: str) -> RepoInfo | None:
    """Fetch basic information for a GitHub repository.

    Args:
        owner: The repository owner (user or organization).
        repo: The repository name.

    Returns:
        A RepoInfo dictionary containing stars, forks, description,
        full_name, and language, or None if the request fails.

    Raises:
        requests.RequestException: If the API request fails.
    """
    url = f"{GITHUB_API_BASE}/repos/{owner}/{repo}"
    headers = {}
    if GITHUB_TOKEN:
        headers["Authorization"] = f"Bearer {GITHUB_TOKEN}"

    logger.info("Fetching repository info: %s/%s", owner, repo)

    response = requests.get(url, headers=headers, timeout=30)
    response.raise_for_status()

    data = response.json()

    result: RepoInfo = {
        "stars": data.get("stargazers_count", 0),
        "forks": data.get("forks_count", 0),
        "description": data.get("description") or "",
        "full_name": data.get("full_name", ""),
        "language": data.get("language"),
    }

    logger.info(
        "Successfully fetched repo info: %s (stars=%d, forks=%d)",
        result["full_name"],
        result["stars"],
        result["forks"],
    )

    return result
